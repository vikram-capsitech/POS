# ──────────────────────────────────────────────────────────
#  OutletOps / POS Client — Vite Environment Variables
#  Copy to .env and fill in values before building.
# ──────────────────────────────────────────────────────────

# Backend API base URL (leave empty to use same origin —
# works when backend serves frontend via SERVE_FRONTEND=true)
VITE_SERVER_URI=https://your-backend-domain.com
