# ──────────────────────────────────────────────────────────
#  OutletOps / POS Backend — Environment Variables
#  Copy this file to .env and fill in the real values.
#  NEVER commit your .env to version control.
# ──────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
PORT=8080

# Frontend URL (used for CORS) — set to your deployed URL
FRONTEND_URL=https://your-frontend-domain.com

# Set to "true" if you want the backend to serve the built
# React app at /, "false" for API-only (split-deploy) mode
SERVE_FRONTEND=false

# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth / JWT ────────────────────────────────────────────
ACCESS_TOKEN_SECRET=replace_with_a_long_random_string
REFRESH_TOKEN_SECRET=replace_with_another_long_random_string

# ── Cloudinary (file uploads) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Nodemailer (email sending) ────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# ── Firebase Cloud Messaging (push notifications) ─────────
# Leave blank to disable push notifications (in-app still works)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com

# ── Google Gemini AI (chatbot) ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
